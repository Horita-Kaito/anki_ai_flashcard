# ============================================
# 共通環境変数 (全環境)
# 環境別の値は .env.dev / .env.staging / .env.prod を参照
# ============================================

# === Compose設定 ===
# 開発: COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
# ステージング: COMPOSE_FILE=docker-compose.yml:docker-compose.staging.yml
# 本番: COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# === Database ===
DB_DATABASE=anki_ai_flashcard
DB_USERNAME=app_user
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=root_password

# === AI Providers ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o-mini
