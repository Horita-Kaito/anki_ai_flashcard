# ============================================
# 本番環境 (.env.prod)
# ============================================

COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml

# === App ===
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.your-domain.com
APP_KEY=

# === Database ===
DB_DATABASE=anki_ai_flashcard
DB_USERNAME=anki_prod_user
DB_PASSWORD=CHANGE_ME_strong_production_password
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password

# === Frontend ===
NEXT_PUBLIC_API_URL=https://api.your-domain.com
PROD_API_URL=https://api.your-domain.com
PROD_FRONTEND_URL=https://your-domain.com
PROD_FRONTEND_DOMAIN=your-domain.com
PROD_SESSION_DOMAIN=.your-domain.com

# === Auth / CORS ===
SANCTUM_STATEFUL_DOMAINS=your-domain.com
SESSION_DOMAIN=.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# === AI Providers ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o-mini

# === Admin ===
# カンマ区切り。ここに含まれる email のユーザーだけが管理画面にアクセス可能。
ADMIN_EMAILS=horitapublic@gmail.com

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === Queue ===
QUEUE_CONNECTION=redis

# === Mail ===
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-domain.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# === Logging ===
LOG_CHANNEL=daily
LOG_LEVEL=warning

# === Session ===
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true
